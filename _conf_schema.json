{
    "monitored_groups": {
        "description": "监控的群聊列表（群号，多个用逗号分隔）",
        "type": "string",
        "hint": "例如: 123456789,987654321",
        "default": ""
    },
    "target_group": {
        "description": "发送总结的目标群（群号）",
        "type": "string",
        "hint": "总结报告和归档文件将发送到此群",
        "default": ""
    },
    "summary_schedule": {
        "description": "定时总结时间（24小时制）",
        "type": "string",
        "hint": "例如: 22:00 表示每天晚上10点自动总结",
        "default": "22:00"
    },
    "summary_hours": {
        "description": "总结时间范围（小时）",
        "type": "int",
        "slider": {
            "min": 1,
            "max": 72,
            "step": 1
        },
        "default": 24
    },
    "max_msg_count": {
        "description": "用于分析的最大消息量(条)",
        "type": "int",
        "slider": {
            "min": 200,
            "max": 5000,
            "step": 100
        },
        "default": 500
    },
    "max_query_rounds": {
        "description": "获取群消息的最大轮数(轮)，每轮最多获取200条",
        "type": "int",
        "slider": {
            "min": 2,
            "max": 100,
            "step": 10
        },
        "default": 20
    },
    "token_limit": {
        "description": "单次查询的消息token限制",
        "type": "int",
        "slider": {
            "min": 10000,
            "max": 100000,
            "step": 2000
        },
        "default": 15000
    },
    "provider_id": {
        "description": "用于生成总结的LLM提供商",
        "hint": "留空或者填写的提供商不存在时，则使用当前正在使用的LLM提供商",
        "type": "string",
        "default": "",
        "_special": "select_provider"
    },
    "bot_name": {
        "description": "BOT名称",
        "type": "string",
        "default": "BOT"
    }
}
